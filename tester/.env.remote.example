# Remote environment
#
# Choose one API mode:
# - API_MODE=be_router: call BE-router (auth required)
# - API_MODE=direct: call GM/State/Scenario services directly (no auth)

# --- Option A) BE-router mode ---
# API_MODE=be_router
# BE_ROUTER_URL=http://<REMOTE_HOST>:18010

# --- Option B) Direct mode (common when only state-manager:8030 is exposed) ---
API_MODE=direct
# If you already have REMOTE_HOST exported in the shell, you can omit the URLs
# and the tester will infer defaults:
#   GM_URL=http://$REMOTE_HOST:8020
#   STATE_MANAGER_URL=http://$REMOTE_HOST:8030
GM_URL=http://<REMOTE_HOST>:8020
STATE_MANAGER_URL=http://<REMOTE_HOST>:8030
# Only needed if you want remote create/inject via scenario-service:
SCENARIO_SERVICE_URL=http://<REMOTE_HOST>:8040

# LLM Gateway (tester agent uses this for action selection)
LLM_GATEWAY_URL=http://<REMOTE_HOST>:8060
LLM_MODEL_NAME=gemini-2.0-flash-lite

# Use an existing account on remote (example: admin/admin)
TESTER_USERNAME=admin
TESTER_PASSWORD=admin
TESTER_EMAIL=admin@example.local
